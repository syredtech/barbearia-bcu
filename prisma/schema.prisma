datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id            String          @id @default(cuid())
  name          String
  email         String          @unique
  password      String?
  role          String          @default("client")
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  accounts      Account[]
  sessions      Session[]
  venue         Venue?
  agendamentos  Agendamento[]
  notificacoes  Notificacao[]
  reviews       Review[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Venue {
  id                    String        @id @default(cuid())
  slug                  String        @unique
  name                  String
  description           String?
  category              String        @default("barbearia")
  address               String?
  phone                 String?
  imageUrl              String?
  latitude              Float?
  longitude             Float?
  status                String        @default("pending")
  stripeCustomerId      String?
  stripeSubscriptionId  String?
  subscriptionStatus    String?
  subscriptionExpiresAt DateTime?
  ownerId               String        @unique
  owner                 User          @relation(fields: [ownerId], references: [id])
  servicos              Servico[]
  agendamentos          Agendamento[]
  scheduleStart         String        @default("09:00")
  scheduleEnd           String        @default("18:00")
  slotDuration          Int           @default(60)
  breakStart            String?
  breakEnd              String?
  closedDays            String        @default("[]")
  break2Start           String?
  break2End             String?
  reviews               Review[]
  funcionarios          Funcionario[]
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt
}

model Funcionario {
  id        String   @id @default(cuid())
  name      String
  venueId   String
  venue     Venue    @relation(fields: [venueId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model Servico {
  id           String        @id @default(cuid())
  name         String
  description  String?
  duration     Int
  price        Float
  venueId      String
  venue        Venue         @relation(fields: [venueId], references: [id], onDelete: Cascade)
  agendamentos Agendamento[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model Agendamento {
  id         String   @id @default(cuid())
  date       String
  horario    String
  status     String   @default("confirmed")
  venueId    String
  venue      Venue    @relation(fields: [venueId], references: [id])
  servicoId  String
  servico    Servico  @relation(fields: [servicoId], references: [id])
  clientId   String?
  client     User?    @relation(fields: [clientId], references: [id])
  guestName  String?
  guestPhone String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  review     Review?
}

model Notificacao {
  id        String   @id @default(cuid())
  ownerId   String
  owner     User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  title     String
  body      String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Review {
  id            String      @id @default(cuid())
  rating        Int
  comment       String?
  venueId       String
  venue         Venue       @relation(fields: [venueId], references: [id], onDelete: Cascade)
  agendamentoId String      @unique
  agendamento   Agendamento @relation(fields: [agendamentoId], references: [id])
  clientId      String
  client        User        @relation(fields: [clientId], references: [id])
  createdAt     DateTime    @default(now())
}
